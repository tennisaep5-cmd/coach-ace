.modal-btn { width:100%; padding:12px; border:none; border-radius:10px; font-family:var(--font-head); font-size:17px; font-weight:700; letter-spacing:1px; cursor:pointer; margin-bottom:7px; transition:background 0.15s; }
.modal-btn.gold { background:var(--gold); color:#fff; }
.modal-btn.gold:hover { background:var(--gold2); }
.modal-btn.secondary { background:transparent; border:1.5px solid var(--border); color:var(--text2); font-size:13px; }
