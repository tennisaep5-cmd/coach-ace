.new-chat-btn { background:var(--green); border:none; color:#fff; border-radius:6px; padding:3px 8px; font-size:10px; font-family:var(--font-body); font-weight:600; cursor:pointer; transition:background 0.13s; }
.new-chat-btn:hover { background:var(--green2); }
