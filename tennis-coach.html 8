.chat-hdr { padding:12px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:10px; flex-shrink:0; background:#fff; box-shadow:var(--shadow); }
.coach-ava { width:32px; height:32px; border-radius:50%; background:var(--green); display:flex; align-items:center; justify-content:center; font-size:14px; border:2px solid var(--green-light); flex-shrink:0; }
