<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Coach Ace — AI Tennis Coach</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

<!-- Firebase -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getAuth, GoogleAuthProvider, signInWithPopup, createUserWithEmailAndPassword, signInWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
  import { getFirestore, collection, addDoc, getDocs, query, orderBy, doc, setDoc, getDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  // ── PASTE YOUR FIREBASE CONFIG HERE ──
  const firebaseConfig = {
    apiKey: "AIzaSyDpdyeP_17VkNbLsC8mfxLT0k16T10q3Rk",
    authDomain: "coach-ace-133d8.firebaseapp.com",
    projectId: "coach-ace-133d8",
    storageBucket: "coach-ace-133d8.firebasestorage.app",
    messagingSenderId: "111251018462",
    appId: "1:111251018462:web:ddecd6dfbcf71a0d11684f"
  };

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);
  const googleProvider = new GoogleAuthProvider();

  let currentUser = null;
  let currentSessionId = null;

  // Auth state
  onAuthStateChanged(auth, async (user) => {
    if (user) {
      currentUser = user;
      document.getElementById('auth-screen').style.display = 'none';
      document.getElementById('app-screen').style.display = 'grid';
      document.getElementById('user-name').textContent = user.displayName || user.email.split('@')[0];
      document.getElementById('user-email').textContent = user.email;
      if (user.photoURL) document.getElementById('user-avatar').src = user.photoURL;
      await loadSessions();
      startNewSession();
      updateUsageUI();
    } else {
      currentUser = null;
      document.getElementById('auth-screen').style.display = 'flex';
      document.getElementById('app-screen').style.display = 'none';
    }
  });

  // ── AUTH ──
  window.signInGoogle = async () => {
    try {
      await signInWithPopup(auth, googleProvider);
    } catch (e) { showAuthErr(e.message); }
  };

  window.signInEmail = async () => {
    const email = document.getElementById('auth-email').value.trim();
    const pass = document.getElementById('auth-pass').value;
    const mode = document.getElementById('auth-mode').dataset.mode;
    if (!email || !pass) { showAuthErr('Please enter email and password.'); return; }
    try {
      if (mode === 'signup') await createUserWithEmailAndPassword(auth, email, pass);
      else await signInWithEmailAndPassword(auth, email, pass);
    } catch (e) {
      const msg = e.code === 'auth/wrong-password' ? 'Wrong password.' :
                  e.code === 'auth/user-not-found' ? 'No account with that email.' :
                  e.code === 'auth/email-already-in-use' ? 'Email already in use — try signing in.' :
                  e.code === 'auth/weak-password' ? 'Password must be at least 6 characters.' :
                  e.message;
      showAuthErr(msg);
    }
  };

  window.signOutUser = async () => { await signOut(auth); };

  function showAuthErr(msg) {
    const el = document.getElementById('auth-err');
    el.textContent = msg; el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 4000);
  }

  window.toggleAuthMode = () => {
    const btn = document.getElementById('auth-mode');
    const isSignup = btn.dataset.mode === 'signup';
    btn.dataset.mode = isSignup ? 'signin' : 'signup';
    document.getElementById('auth-submit').textContent = isSignup ? 'Sign In' : 'Create Account';
    document.getElementById('auth-toggle-text').innerHTML = isSignup
      ? 'Don\'t have an account? <span onclick="toggleAuthMode()">Sign up</span>'
      : 'Already have an account? <span onclick="toggleAuthMode()">Sign in</span>';
    document.getElementById('auth-title').textContent = isSignup ? 'Welcome Back' : 'Create Account';
  };

  // ── SESSIONS ──
  window.startNewSession = async () => {
    currentSessionId = Date.now().toString();
    window._history = [];
    document.getElementById('messages').innerHTML = '';
    showWelcome();
    highlightSession(null);
  };

  async function loadSessions() {
    if (!currentUser) return;
    try {
      const q = query(collection(db, 'users', currentUser.uid, 'sessions'), orderBy('createdAt', 'desc'));
      const snap = await getDocs(q);
      const list = document.getElementById('session-list');
      list.innerHTML = '';
      snap.forEach(d => {
        const data = d.data();
        const btn = document.createElement('button');
        btn.className = 'session-btn';
        btn.dataset.id = d.id;
        btn.innerHTML = `<span class="session-ico">💬</span><span class="session-label">${data.title || 'Session'}</span>`;
        btn.onclick = () => loadSession(d.id, data);
        list.appendChild(btn);
      });
    } catch(e) { console.log('Load sessions error:', e); }
  }

  async function loadSession(id, data) {
    currentSessionId = id;
    window._history = data.messages || [];
    document.getElementById('messages').innerHTML = '';
    hideWelcome();
    (data.messages || []).forEach(m => {
      if (m.role !== 'system') renderMessage(m.role, m.content);
    });
    highlightSession(id);
  }

  function highlightSession(id) {
    document.querySelectorAll('.session-btn').forEach(b => b.classList.toggle('active', b.dataset.id === id));
  }

  window.saveSession = async (title) => {
    if (!currentUser || !currentSessionId) return;
    try {
      await setDoc(doc(db, 'users', currentUser.uid, 'sessions', currentSessionId), {
        title: title || 'Tennis Session',
        messages: window._history,
        createdAt: serverTimestamp()
      });
      await loadSessions();
      highlightSession(currentSessionId);
    } catch(e) { console.log('Save error:', e); }
  };

  // expose db functions globally
  window._db = db;
  window._currentUser = () => currentUser;
</script>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
