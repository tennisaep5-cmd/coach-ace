<script>
const SYSTEM_PROMPT = `You are Coach Ace — an elite tennis coach AND tennis encyclopaedia. Direct, passionate, real. Sound like a coach on court, not a chatbot.

You have deep knowledge of ALL professional tennis players — ATP, WTA, ITF juniors, college tennis, and legends. This includes:
- Current ATP & WTA rankings (you know the top 200+)
- Player styles, strengths, weaknesses, signature shots
- Grand Slam records, career stats, head-to-head records
- Junior players, rising stars, national team players
- Coaching backgrounds, training methods
- Recent form, injuries, tournament results
- Historical legends: Federer, Sampras, Navratilova, Graf, Agassi etc.

When asked about a player: give their current ranking, playing style, key stats, and a coaching insight about what makes them great or what they struggle with. Be specific and confident.

For TECHNIQUE / photo analysis — keep it tight:
[VERDICT] One honest sentence.

WHAT YOU'RE DOING WELL
✅ Point (one line)
✅ Point (one line)

WHAT NEEDS WORK
❌ Issue — why it hurts (one line)
❌ Issue — why it hurts (one line)

COACH'S PRESCRIPTION
💡 Drill name + one sentence how-to
💡 Mental cue

SCORE: X/10 — One line on what raises it.

For PLAYER / RANKING questions:
Give ranking, nationality, playing style, best shots, notable achievements, and one coaching insight. Keep it to 4-5 lines.

For TACTICAL / MENTAL / GENERAL questions:
3-4 sentences max. Sharp, specific, real examples. No fluff.

ALWAYS end with:
FOLLOW_UP_QUESTIONS:
- [Dig deeper]
- [Related area]
- [Challenge them]`;

const FREE_LIMIT = 10;
let attachedFiles = [], busy = false;
window._history = window._history || [];

function today() { return new Date().toDateString(); }
function getUsage() {
  const s = localStorage.getItem('ace_usage');
  if (!s) return { count:0, date:today() };
  const u = JSON.parse(s);
  return u.date !== today() ? { count:0, date:today() } : u;
}
function incrementUsage() {
  const u = getUsage(); u.count++;
  localStorage.setItem('ace_usage', JSON.stringify(u));
  updateUsageUI();
}
function isPremium() { return localStorage.getItem('ace_premium') === 'true'; }
function isLimited() { return !isPremium() && getUsage().count >= FREE_LIMIT; }

function updateUsageUI() {
  const u = getUsage(), premium = isPremium();
  const pill = document.getElementById('plan-pill');
  const wrap = document.getElementById('usage-wrap');
  const hdrBtn = document.getElementById('upgrade-hdr-btn');
  if (premium) {
    pill.className='plan-pill premium'; pill.textContent='⭐ Pro';
    wrap.style.display='none'; hdrBtn.classList.add('hidden');
    document.getElementById('limit-banner').style.display='none';
    document.getElementById('input-box').classList.remove('locked');
    document.getElementById('input-hint').innerHTML='Unlimited — <span style="color:var(--good)">Pro Active ✓</span>';
    document.getElementById('fi').accept='image/*,video/*';
  } else {
    pill.className='plan-pill free'; pill.textContent='✓ Free';
    wrap.style.display='block'; hdrBtn.classList.remove('hidden');
    const pct = Math.min((u.count/FREE_LIMIT)*100,100);
    document.getElementById('usage-text').textContent=`${u.count} / ${FREE_LIMIT} today`;
    const fill=document.getElementById('usage-fill');
    fill.style.width=pct+'%';
    fill.className='usage-fill'+(pct>=100?' full':pct>=66?' warn':'');
    if (u.count>=FREE_LIMIT) {
      document.getElementById('limit-banner').style.display='flex';
      document.getElementById('input-box').classList.add('locked');
      startResetTimer();
    } else {
      document.getElementById('limit-banner').style.display='none';
      document.getElementById('input-box').classList.remove('locked');
    }
    const rem=FREE_LIMIT-u.count;
    document.getElementById('input-hint').innerHTML=rem>0
      ?`Enter to send · <strong>${rem} free ${rem===1?'analysis':'analyses'} left</strong> · <span style="color:var(--gold2);cursor:pointer" onclick="showPaywall()">Go unlimited →</span>`
      :`Limit reached · <span style="color:var(--gold2);cursor:pointer;font-weight:600" onclick="showPaywall()">Upgrade →</span>`;
  }
}

function startResetTimer() {
  clearInterval(window._rt);
  function tick(){
    const now=new Date(),midnight=new Date(now);midnight.setHours(24,0,0,0);
    const diff=midnight-now;
    const h=String(Math.floor(diff/3600000)).padStart(2,'0');
    const m=String(Math.floor((diff%3600000)/60000)).padStart(2,'0');
    const s=String(Math.floor((diff%60000)/1000)).padStart(2,'0');
    const el=document.getElementById('reset-timer');if(el)el.textContent=`${h}:${m}:${s}`;
  }
  tick();window._rt=setInterval(tick,1000);
}

function showPaywall(){document.getElementById('modal-paywall').style.display='flex';}
function closePaywall(){document.getElementById('modal-paywall').style.display='none';}
function goPro(){window.location.href='https://buy.stripe.com/YOUR_LINK';}
function handleVideoClick(){if(!isPremium()){showPaywall();return;}document.getElementById('fi').accept='image/*,video/*';document.getElementById('fi').click();}

function getKey(){return localStorage.getItem('ace_groq_key')||'';}
function activateKey(){
  const k=document.getElementById('key-input').value.trim();
  const err=document.getElementById('key-err');
  if(!k){err.textContent='Please paste your key.';return;}
  if(!k.startsWith('gsk_')){err.textContent='Groq keys start with "gsk_"';return;}
  localStorage.setItem('ace_groq_key',k);
  document.getElementById('modal-key').style.display='none';
}
window.resetKey=()=>{localStorage.removeItem('ace_groq_key');document.getElementById('key-input').value='';document.getElementById('modal-key').style.display='flex';};

function checkKey(){if(!getKey()){document.getElementById('modal-key').style.display='flex';return false;}return true;}

const scroll=()=>{const m=document.getElementById('messages');m.scrollTop=m.scrollHeight;};

function showWelcome(){
  const msgs=document.getElementById('messages');
  msgs.innerHTML=`<div class="welcome"><div class="welcome-ico"><img src="data:image/jpeg;base64," style="width:60px;height:60px;border-radius:14px;object-fit:cover;" /></div><div class="welcome-title">READY TO WORK?</div><div class="welcome-sub">Ask me anything, or attach a photo for technique analysis. Free: 10 analyses/day.</div></div>`;
}
function hideWelcome(){const w=document.querySelector('.welcome');if(w)w.remove();}

function toB64(file){
  return new Promise((res,rej)=>{const r=new FileReader();r.onload=()=>res(r.result.split(',')[1]);r.onerror=rej;r.readAsDataURL(file);});
}

function renderCoach(raw){
  let main=raw,fuqs=[];
  const m=raw.match(/FOLLOW_UP_QUESTIONS:\s*([\s\S]+)$/i);
  if(m){main=raw.slice(0,m.index).trim();fuqs=m[1].split('\n').map(l=>l.replace(/^[-•*\d.]\s*/,'').trim()).filter(l=>l.length>8).slice(0,3);}
  let html=main
    .replace(/\[VERDICT\]\s*[—–-]?\s*/gi,'<div class="verdict">')
    .replace(/\n(WHAT YOU'RE DOING WELL|WHAT NEEDS WORK|COACH'S PRESCRIPTION)\n/gi,(_,t)=>`</div><div class="sec-title">${t}</div>`)
    .replace(/SCORE:\s*(\d+)\/10\s*[—–-]?\s*([^\n]*)/gi,(_,s,note)=>`<div class="score-wrap"><div class="score-lbl"><strong>Score: ${s}/10</strong>${note?' — '+note.trim():''}</div><div class="score-track"><div class="score-fill-bar" style="width:${s*10}%"></div></div></div>`)
    .replace(/✅\s*([^\n]+)/g,'<div class="citem"><span class="ico">✅</span><span style="color:#16a34a">$1</span></div>')
    .replace(/❌\s*([^\n]+)/g,'<div class="citem"><span class="ico">❌</span><span style="color:#dc2626">$1</span></div>')
    .replace(/💡\s*([^\n]+)/g,'<div class="citem"><span class="ico">💡</span><span style="color:#d97706">$1</span></div>')
    .replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>')
    .replace(/\n{2,}/g,'<br><br>').replace(/\n/g,'<br>');
  const opens=(html.match(/<div/g)||[]).length,closes=(html.match(/<\/div>/g)||[]).length;
  for(let i=0;i<opens-closes;i++)html+='</div>';
  let out=`<div>${html}</div>`;
  if(fuqs.length)out+=`<div class="follow-up"><div class="fu-label">Keep going →</div>${fuqs.map(q=>`<button class="fq" onclick="quickAsk(this.textContent)">${q}</button>`).join('')}</div>`;
  return out;
}

function renderMessage(role,text,media){
  hideWelcome();
  const row=document.createElement('div');row.className='msg-row '+role;
  const ava=document.createElement('div');ava.className='msg-ava';if(role==='assistant'){ava.innerHTML='<img src="data:image/jpeg;base64," style="width:100%;height:100%;border-radius:50%;object-fit:cover;"/>';}else{ava.textContent='👤';}
  const bub=document.createElement('div');bub.className='bubble';
  if(media&&media.length){media.forEach(m=>{const d=document.createElement('div');d.className='mprev';const img=document.createElement('img');img.src=m.url;d.appendChild(img);bub.appendChild(d);});}
  if(text){if(role==='assistant')bub.innerHTML+=renderCoach(text);else{const t=document.createElement('div');t.textContent=text;bub.appendChild(t);}}
  row.appendChild(ava);row.appendChild(bub);
  document.getElementById('messages').appendChild(row);scroll();
}

function showTyping(){
  const row=document.createElement('div');row.className='typing-row';row.id='typ';
  const ava=document.createElement('div');ava.className='msg-ava';ava.style.cssText='background:var(--green);border:2px solid var(--green-light)';ava.innerHTML='<img src="data:image/jpeg;base64," style="width:100%;height:100%;border-radius:50%;object-fit:cover;"/>';
  const bub=document.createElement('div');bub.className='typing-bub';bub.innerHTML='<span></span><span></span><span></span>';
  row.appendChild(ava);row.appendChild(bub);
  document.getElementById('messages').appendChild(row);scroll();
}
const rmTyping=()=>{const t=document.getElementById('typ');if(t)t.remove();};

function isPlayerQuery(text){
  const t=text.toLowerCase();
  const kw=['ranking','ranked','wta','atp','who is','tell me about','djokovic','alcaraz','sinner','medvedev','federer','nadal','serena','swiatek','sabalenka','gauff','rybakina','zverev','tsitsipas','murray','williams','junior','pro player','professional','career stats','grand slam','wimbledon','french open','us open','australian open','seeded','seed','tour player','itf'];
  return kw.some(k=>t.includes(k));
}

async function callGroq(messages){
  const key=getKey();
  if(!key){document.getElementById('modal-key').style.display='flex';throw new Error('NO_KEY');}
  const lastMsg=messages[messages.length-1]?.content||'';
  const useSearch=isPlayerQuery(lastMsg);
  const body={
    model:useSearch?'compound-beta':'llama-3.3-70b-versatile',
    max_tokens:700,
    temperature:0.7,
    messages:[{role:'system',content:SYSTEM_PROMPT},...messages]
  };
  const res=await fetch('https://api.groq.com/openai/v1/chat/completions',{
    method:'POST',
    headers:{'Content-Type':'application/json','Authorization':`Bearer ${key}`},
    body:JSON.stringify(body)
  });
  const data=await res.json();
  if(!res.ok)throw new Error(data?.error?.message||`Error ${res.status}`);
  return data.choices?.[0]?.message?.content||'';
}

async function send(){
  if(busy)return;
  if(!checkKey())return;
  if(isLimited()){showPaywall();return;}
  const ta=document.getElementById('msg-ta');
  const text=ta.value.trim();
  if(!text&&!attachedFiles.length)return;
  busy=true;document.getElementById('send-btn').disabled=true;

  const curFiles=[...attachedFiles];
  const media=curFiles.map(f=>({url:f.url,file:f.file}));
  attachedFiles=[];document.getElementById('chips').innerHTML='';
  ta.value='';ta.style.height='auto';

  renderMessage('user',text,media);
  showTyping();

  try{
    let content=text||(media.length?'Analyse my tennis technique.':'');
    if(media.length)content='[Photo of tennis player attached — analyse technique] '+(text||'');
    window._history.push({role:'user',content});
    const reply=await callGroq(window._history);
    window._history.push({role:'assistant',content:reply});
    incrementUsage();
    rmTyping();renderMessage('assistant',reply);

    // Auto-save session with title from first message
    const title=window._history.find(m=>m.role==='user')?.content?.slice(0,40)||'Tennis Session';
    if(typeof saveSession==='function')saveSession(title);

    if(!isPremium()&&getUsage().count>=FREE_LIMIT){
      setTimeout(()=>{renderMessage('assistant',"Last free analysis for today ⏳\n\nUpgrade to Pro for unlimited + video — $6/month. Or come back tomorrow!");},700);
    }
  }catch(e){
    if(window._history.length&&window._history[window._history.length-1].role==='user')window._history.pop();
    rmTyping();
    if(e.message!=='NO_KEY')renderMessage('assistant','⚠️ '+(e.message||'Something went wrong.'));
  }
  busy=false;document.getElementById('send-btn').disabled=false;ta.focus();
  updateUsageUI();
}

function quickAsk(q){document.getElementById('msg-ta').value=q;send();}

document.getElementById('fi').addEventListener('change',e=>{
  Array.from(e.target.files).forEach(f=>{
    if(f.type.startsWith('video')&&!isPremium()){showPaywall();return;}
    const url=URL.createObjectURL(f);
    attachedFiles.push({file:f,url});
    const chip=document.createElement('div');chip.className='chip';
    chip.innerHTML=`<span>🖼</span><span>${f.name.length>16?f.name.slice(0,14)+'…':f.name}</span><button class="chip-x">×</button>`;
    chip.querySelector('.chip-x').onclick=()=>{attachedFiles=attachedFiles.filter(x=>x.url!==url);chip.remove();};
    document.getElementById('chips').appendChild(chip);
  });
  e.target.value='';
});

const ta=document.getElementById('msg-ta');
ta.addEventListener('input',()=>{ta.style.height='auto';ta.style.height=Math.min(ta.scrollHeight,100)+'px';});
ta.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send();}});

// Show welcome on load
document.addEventListener('DOMContentLoaded',()=>{
  const msgs=document.getElementById('messages');
  if(msgs&&!msgs.children.length)showWelcome();
});
</script>
