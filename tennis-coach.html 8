.input-box.locked { opacity:0.6; pointer-events:none; }
.attach-btn { width:28px; height:28px; background:none; border:none; cursor:pointer; color:var(--text3); font-size:14px; display:flex; align-items:center; justify-content:center; border-radius:6px; flex-shrink:0; }
.attach-btn:hover { color:var(--green); }
.msg-ta { flex:1; background:none; border:none; outline:none; color:var(--text); font-family:var(--font-body); font-size:13.5px; resize:none; min-height:21px; max-height:100px; line-height:1.5; padding:3px 0; }
.msg-ta::placeholder { color:var(--text3); }
.send-btn { width:30px; height:30px; border-radius:8px; border:none; background:var(--green); cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:12px; color:#fff; flex-shrink:0; transition:background 0.13s; }
.send-btn:hover { background:var(--green2); }
.send-btn:disabled { background:var(--border); cursor:not-allowed; color:var(--text3); }
.input-hint { font-size:10px; color:var(--text3); text-align:center; margin-top:5px; }
