.key-input { width:100%; background:var(--bg2); border:1.5px solid var(--border); border-radius:9px; padding:11px 13px; font-size:13.5px; font-family:monospace; color:var(--text); outline:none; margin-bottom:8px; transition:border-color 0.15s; }
