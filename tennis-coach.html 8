.chip-x:hover { color:var(--text); }
.input-box { display:flex; gap:8px; align-items:flex-end; background:var(--bg2); border:1.5px solid var(--border); border-radius:13px; padding:8px 10px; transition:border-color 0.15s,box-shadow 0.15s; }
